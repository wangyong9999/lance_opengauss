FROM opengauss-build:latest

# Install additional deps for lance_fdw build
RUN yum install -y unzip perl-IPC-Cmd && yum clean all

# Install protoc
RUN curl -sSL -o /tmp/protoc.zip \
    "https://github.com/protocolbuffers/protobuf/releases/download/v25.1/protoc-25.1-linux-x86_64.zip" && \
    cd /tmp && unzip -o protoc.zip -d /usr/local bin/protoc 'include/*' && \
    chmod +x /usr/local/bin/protoc && rm -f /tmp/protoc.zip

# Install Rust
RUN curl --proto '=https' --tlsv1.2 -sSf https://sh.rustup.rs | sh -s -- -y --default-toolchain stable
ENV PATH="/root/.cargo/bin:${PATH}"

WORKDIR /build
CMD ["/bin/bash"]
